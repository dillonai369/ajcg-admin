# =================================================================
# AJ Commercial Group — environment variables
#
# 1. Copy this file:   cp .env.example .env.local
# 2. Paste your real keys below
# 3. Restart `npm run dev`
#
# IMPORTANT: .env.local is gitignored. Never commit secret keys.
# =================================================================

# -----------------------------------------------------------------
# SUPABASE (database + image storage)
# Get these from: https://app.supabase.com → your project → Settings → API
# -----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-public-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-secret-key...

# -----------------------------------------------------------------
# CLERK (auth — login for Joey & Anthony)
# Get these from: https://dashboard.clerk.com → your app → API Keys
# -----------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# -----------------------------------------------------------------
# ANTHROPIC (AI-assist features in blog/listing editors)
# Get this from: https://console.anthropic.com → API Keys
# -----------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
